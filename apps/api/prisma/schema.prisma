generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id              String        @id @default(uuid())
  name            String
  industry        String?
  website         String?
  description     String?
  isDesignPartner Boolean       @default(false)
  tags            String[]      @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  contacts        Contact[]
  opportunities   Opportunity[]
  interviews      Interview[]
  evidence        Evidence[]
  scores          OpportunityScore[]
  intakes         ArchitectureIntake[]
}

model Contact {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  email     String
  role      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  source    String?
  status    String   @default("new")
  notes     String?
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Opportunity {
  id              String   @id @default(uuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title           String
  stage           String   @default("prospect")
  value           Float?
  isDesignPartner Boolean  @default(false)
  closeDate       DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  interviews      Interview[]
  evidence        Evidence[]
  scores          OpportunityScore[]
}

model InterviewTemplate {
  id          String      @id @default(uuid())
  name        String
  persona     String
  description String?
  questions   String[]    @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  interviews  Interview[]
}

model Interview {
  id             String             @id @default(uuid())
  accountId      String
  account        Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  opportunityId  String?
  opportunity    Opportunity?       @relation(fields: [opportunityId], references: [id])
  templateId     String?
  template       InterviewTemplate? @relation(fields: [templateId], references: [id])
  interviewer    String
  interviewee    String
  persona        String
  status         String             @default("scheduled")
  scheduledAt    DateTime
  completedAt    DateTime?
  notes          String             @default("")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  evidence       Evidence[]
}

model Evidence {
  id               String      @id @default(uuid())
  title            String
  description      String
  category         String
  sourceType       String
  sourceReference  String?
  tags             String[]    @default([])
  accountId        String?
  account          Account?    @relation(fields: [accountId], references: [id])
  opportunityId    String?
  opportunity      Opportunity? @relation(fields: [opportunityId], references: [id])
  interviewId      String?
  interview        Interview?  @relation(fields: [interviewId], references: [id])
  hypothesisId     String?
  hypothesis       Hypothesis? @relation(fields: [hypothesisId], references: [id])
  confidence       String      @default("medium")
  impact           String      @default("medium")
  createdBy        String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Hypothesis {
  id        String     @id @default(uuid())
  statement String
  status    String     @default("unvalidated")
  evidence  Evidence[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model ArchitectureIntake {
  id               String   @id @default(uuid())
  accountId        String?
  account          Account? @relation(fields: [accountId], references: [id])
  organizationName String
  applicationName  String
  description      String?
  primaryContact   String
  cloudProviders   String[] @default([])
  environments     String[] @default([])
  compute          Json     @default("{}")
  storage          Json     @default("{}")
  messaging        Json     @default("{}")
  identity         Json     @default("{}")
  networking       Json     @default("{}")
  cicd             Json     @default("{}")
  observability    Json     @default("{}")
  security         Json     @default("{}")
  compliance       String[] @default([])
  dataResidency    String?
  disasterRecovery String?
  integrations     String[] @default([])
  portabilityGoals String?
  status           String   @default("draft")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  assessments      Assessment[]
}

model OpportunityScore {
  id            String      @id @default(uuid())
  accountId     String
  account       Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  totalScore    Float
  rating        String
  breakdown     Json
  calculatedAt  DateTime    @default(now())
}

model ScoringConfig {
  id                     String   @id @default(uuid())
  strategicFit           Float    @default(0.20)
  cloudComplexity        Float    @default(0.15)
  vendorLockInRisk       Float    @default(0.15)
  technicalMaturity      Float    @default(0.10)
  revenuePotential       Float    @default(0.15)
  urgency                Float    @default(0.10)
  regulatoryPressure     Float    @default(0.05)
  innovationReadiness    Float    @default(0.05)
  designPartnerPotential Float    @default(0.03)
  referenceValue         Float    @default(0.02)
  updatedAt              DateTime @updatedAt
}

model Assessment {
  id               String              @id @default(uuid())
  name             String
  organizationName String
  projectName      String
  status           String              @default("draft")
  intakeId         String?
  intake           ArchitectureIntake? @relation(fields: [intakeId], references: [id])
  inventory        PortabilityInventory?
  portabilityScore PortabilityScore?
  recommendations  Recommendation[]
  reports          AdvisoryReport[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model PortabilityInventory {
  id               String         @id @default(uuid())
  assessmentId     String         @unique
  assessment       Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  providerSummaries Json          @default("[]")
  services         CloudService[]
  lockInRisks      LockInRisk[]
  createdAt        DateTime       @default(now())
}

model CloudService {
  id          String               @id @default(uuid())
  inventoryId String
  inventory   PortabilityInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  name        String
  provider    String
  category    String
  type        String
  equivalents String[]             @default([])
}

model LockInRisk {
  id             String               @id @default(uuid())
  inventoryId    String
  inventory      PortabilityInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  service        String
  provider       String
  description    String
  severity       String
  recommendation String?
}

model PortabilityScore {
  id           String      @id @default(uuid())
  assessmentId String      @unique
  assessment   Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  overallScore Float
  rating       String
  modelVersion String      @default("v1")
  dimensions   Json        @default("[]")
  deductions   Json        @default("[]")
  calculatedAt DateTime    @default(now())
}

model Recommendation {
  id                      String     @id @default(uuid())
  assessmentId            String
  assessment              Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  title                   String
  description             String
  category                String
  priority                String
  impact                  String
  effort                  String
  rationale               String
  implementationGuidance  String
  relatedRisks            String[]   @default([])
  relatedServices         String[]   @default([])
  createdAt               DateTime   @default(now())
}

model AdvisoryReport {
  id               String     @id @default(uuid())
  assessmentId     String
  assessment       Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  title            String
  organizationName String
  format           String     @default("markdown")
  version          String     @default("1.0")
  content          String
  metadata         Json       @default("{}")
  generatedAt      DateTime   @default(now())
}

// ─── Pattern Catalog ──────────────────────────────────────────────────────────

model Pattern {
  id            String            @id @default(uuid())
  name          String
  category      String
  description   String
  portability   String            @default("high")
  version       String            @default("1.0.0")
  interfaces    String[]          @default([])
  dependencies  String[]          @default([])
  providers     Json              @default("{}")
  artifacts     Json              @default("{}")
  tags          String[]          @default([])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

// ─── Workspace & Project Model ────────────────────────────────────────────────

model Workspace {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  projects    Project[]
  teams       Team[]
  memberships Membership[]
}

model Project {
  id            String        @id @default(uuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  repositoryUrl String?
  status        String        @default("active")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  environments  Environment[]
  artifacts     Artifact[]
}

model Environment {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  cloudProvider String?
  region        String?
  createdAt     DateTime @default(now())
}

model Team {
  id          String      @id @default(uuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  createdAt   DateTime    @default(now())
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  permissions String[]     @default([])
  memberships Membership[]
}

model Membership {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  createdAt   DateTime  @default(now())
}

model Artifact {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  reference String
  createdAt DateTime @default(now())
}
